#Problem Statement 3: Sampling and the Central Limit Theorem (CLT)
# Population = calculated_host_listings_count
population = df["calculated_host_listings_count"]
# Plot histogram of population
plt.figure(figsize=(8,5))
sns.histplot(population, bins=50, kde=False)
plt.title("Population Distribution (calculated_host_listings_count)")
plt.xlabel("Calculated Host Listings Count")
plt.ylabel("Frequency")
plt.show()
# Population mean
population_mean = population.mean()
print("Population Mean:", population_mean)
#Step 2: Sampling Distribution (CLT Simulation)
# Parameters
sample_size = 50
n_iterations = 1000
sample_means = []
# Draw 1000 random samples
for _ in range(n_iterations):
    sample = population.sample(sample_size, replace=True) 
    sample_means.append(sample.mean())
# Convert to numpy array
sample_means = np.array(sample_means)
#Step 3: Visualize & Verify CLT
# Histogram of sample means
plt.figure(figsize=(8,5))
sns.histplot(sample_means, bins=50, kde=True, color="skyblue")
plt.title("Sample Means (n=50, 1000 samples)")
plt.xlabel("Sample Mean")
plt.ylabel("Frequency")
plt.show()
# Mean of sample means
sampling_mean = sample_means.mean()
print("Mean of Sample Means:", sampling_mean)
print("Population Mean:", population_mean)


